APP_ENV=development
DB_PATH=/app/db/gaokao.db
DATA_DIR=/app/data

# Optional LLM API keys
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
MOONSHOT_API_KEY=

# LLM provider: none / openai / deepseek / qwen / kimi
LLM_PROVIDER=none

# Kimi / Moonshot
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=moonshot-v1-8k